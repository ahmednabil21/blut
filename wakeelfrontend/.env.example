# رابط الباكند - غيّر حسب البيئة
# تطوير محلي (npm start يحمّل .env.development — الافتراضي هناك localhost:5112):
# REACT_APP_API_URL=http://localhost:5112/wakeel/api
# FastAPI SAS — POST /api/auth/login و GET /api/subscribers (محلي: http://localhost:8000)
# REACT_APP_SAS_PYTHON_API_URL=http://localhost:8000
# REACT_APP_SAS_PYTHON_ENABLED=false
# إنتاج سابق (api-v2): https://api-v2.execute-iq.com/wakeel/api
# REACT_APP_API_URL=https://lab.execute-iq.com/wakeel/api
# FastAPI (افتراضي محلي)
REACT_APP_API_URL=https://bult.execute-iq.com/api
REACT_APP_BACKEND=python
# باكند .NET قديم:
# REACT_APP_API_URL=https://wakeelhus-001-site1.rtempurl.com/wakeel/api
#REACT_APP_API_URL=https://api-v2.execute-iq.com/wakeel/api
# خدمة واتساب (wwebjs-api / whapi) - لربط الجلسة وجلب QR
# محلي:
# REACT_APP_WWEBJS_API_URL=http://localhost:3000
# إنتاج (سيرفر + Cloudflare Tunnel):
# REACT_APP_API_URL=https://api.execute-iq.com/wakeel/api
# REACT_APP_WWEBJS_API_URL=https://api.execute-iq.com/whapi
# إنتاج (Railway). لا تضف /api-docs — استخدم أساس الرابط فقط؛ الوثائق: نفس الرابط + /api-docs/
# REACT_APP_WWEBJS_API_URL=https://whapi-production-434d.up.railway.app/whapi
# مفتاح API لـ wwebjs-api (إذا كانت الخدمة تتطلب مصادقة، وإلا اتركه فارغاً)
# REACT_APP_WWEBJS_API_KEY=
# إنتاج (Railway):
# REACT_APP_API_URL=https://wakeelbackend-production.up.railway.app/wakeel/api
# بديل محلي:
# REACT_APP_API_URL=http://localhost:5112/wakeel/api
# مفتاح موقع Cloudflare Turnstile (لصفحة تسجيل الدخول) - احصل عليه من لوحة Turnstile
# REACT_APP_TURNSTILE_SITE_KEY=0x4AAAAAACh0LGLTfAOqhxi6
# تعطيل Turnstile في أي بيئة (مثلاً ستيجينغ غير مضاف في Cloudflare): REACT_APP_TURNSTILE_ENABLED=false
# ملاحظة: في وضع التطوير (npm run start) و على localhost لا يُحمّل Turnstile تلقائياً
